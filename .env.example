# ===========================================
# 사이트 도메인 (선택)
# ===========================================
# Vercel 배포 시 VERCEL_URL이 자동 사용되어 canonical이 실제 접속 URL과 일치합니다.
# run-msg.vercel.app 배포 시 VERCEL_URL 자동 사용. 커스텀 도메인만 쓸 때만 NEXT_PUBLIC_SITE_URL 설정.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ===========================================
# Google Search Console (선택)
# ===========================================
# Search Console 소유권 확인 후 메타태그 방식 사용 시
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=검증코드
# 예: NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=googlecb5637a49a67a4b9
